# FarmFriend Terminal React - Comprehensive .gitignore

# ================================
# Environment & Secrets
# ================================
# Global environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Skills-specific environment files (HIGH SECURITY PRIORITY)
skills/**/.env
skills/**/credentials
skills/**/secrets
skills/**/.env.*
skills/**/config.json
skills/**/.api-keys
skills/**/tokens
skills/**/*.key
skills/**/*.pem
skills/**/*.p12
skills/**/*.pfx

# Profile configurations (may contain sensitive data)
.ff-terminal-profiles.json
*.ff-terminal-profiles.json
profiles.json
.user-profiles

# ================================
# Node.js & TypeScript
# ================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
build/
*.tsbuildinfo

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage
.grunt

# Bower dependency directory
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons
build/Release

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/

# Storybook build outputs
.out
.storybook-out

# agent-testing-suite artifacts
agent-testing-suite/node_modules/
agent-testing-suite/dist/
agent-testing-suite/ff-terminal-workspace/
agent-testing-suite/server.log

