# ================================
# Skill-Specific Ignores
# ================================
# Script outputs and temporary files in skills
skills/**/output/
skills/**/temp/
skills/**/.cache/
skills/**/tmp/
skills/**/*.tmp
skills/**/*.temp

# Skill-specific logs
skills/**/*.log
skills/**/logs/

# Skill build outputs
skills/**/dist/
skills/**/build/
skills/**/out/

# ================================
# Security & Credential Files
# ================================
# Certificate files
*.pem
*.key
*.crt
*.cert
*.cer
*.p12
*.pfx

# AWS, GCP, Azure credentials
.aws/
.gcp/
.azure/
.gcloud/
.boto
.credentials

# API keys and tokens
.api-key
.api_keys
.token
.tokens
.secrets
.secret

# Database files (if any)
*.db
*.sqlite
*.sqlite3
*.mdb

# ================================
# Development Tools
# ================================
# ESLint
.eslintcache

# Stylelint
.stylelintcache

# Prettier
.prettierignore

# Jest
coverage/
.jest/

# Cypress
cypress/videos/
cypress/screenshots/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# ================================
# Misc
# ================================
# FarmFriend specific
farmfriend-*.log
farmfriend-*.tmp

# Local configuration overrides
config.local.json
settings.local.json

# Backup files
*.bak
*.backup
*.old

# Archive files (except intentionally included ones)
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# Lock files (keep package-lock.json but ignore others)
yarn.lock
pnpm-lock.yaml
!package-lock.json

# ================================
# FF-Terminal Workspace (Runtime)
# ================================
# Local runtime home (sessions, state)
.ff-terminal/
# All workspace-generated files should be local-only
ff-terminal-workspace/
# Explicitly allow some workspace files if needed
!ff-terminal-workspace/.gitkeep

# Local cached web UI build (copied from reference frontend dist)
web-frontend-dist/

# User-generated artifacts
news-card-deck.html
ducks_red_raiders_game.html

# DDS prototypes
dds-enterprise-prototypes/

# Session artifacts (thoughts, todos, memories)
ff-terminal-workspace/thoughts/
ff-terminal-workspace/todos/
ff-terminal-workspace/session_summary.md

# Logs (session and scheduled runs)
ff-terminal-workspace/logs/

# Workspace-specific docs (generated)
ff-terminal-workspace/docs/

# Memory and skill cache
ff-terminal-workspace/memory_core/
ff-terminal-workspace/projects/

# Temporary workspace files
.fakehome/
