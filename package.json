{
  "name": "ff-terminal-ts",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ff-terminal": "dist/bin/ff-terminal.js"
  },
  "scripts": {
    "dev": "tsx src/bin/ff-terminal.ts",
    "dev:daemon": "tsx src/daemon/daemon.ts",
    "dev:cli": "tsx src/cli/app.tsx",
    "dev:web": "tsx src/web/server.ts",
    "dev:run": "tsx src/bin/ff-terminal.ts run --prompt \"Hello\"",
    "dev:start": "tsx src/bin/ff-terminal.ts start",
    "dev:web:start": "tsx src/bin/ff-terminal.ts start --web",
    "dev:ws": "tsx src/bin/ff-terminal.ts start -w",
    "build": "npm run build:web && tsc -p tsconfig.json && npm run postbuild",
    "build:web": "cd src/web/client && npm install && npm run build",
    "postbuild": "cp -r src/runtime/tools/implementations/macos_control/kb dist/runtime/tools/implementations/macos_control/ 2>/dev/null || true",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "start:daemon": "node dist/daemon/daemon.js",
    "start:cli": "node dist/cli/app.js",
    "start:web": "node dist/web/server.js"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.40.1",
    "busboy": "^1.6.0",
    "ink": "^5.0.0",
    "inquirer": "^9.2.12",
    "luxon": "^3.7.2",
    "playwright": "^1.57.0",
    "react": "^18.3.1",
    "rrule": "^2.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.5",
    "@types/busboy": "^1.5.4",
    "@types/inquirer": "^9.0.8",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "undici": "^7.16.0",
    "vitest": "^4.0.16"
  }
}
