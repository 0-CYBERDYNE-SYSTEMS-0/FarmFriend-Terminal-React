{
  "name": "ff-terminal-ts",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ff-terminal": "dist/bin/ff-terminal.js"
  },
  "scripts": {
    "dev": "tsx src/bin/ff-terminal.ts",
    "dev:daemon": "tsx src/daemon/daemon.ts",
    "dev:cli": "tsx src/cli/app.tsx",
    "dev:web": "tsx src/web/server.ts",
    "dev:run": "tsx src/bin/ff-terminal.ts run --prompt \"Hello\"",
    "dev:start": "tsx src/bin/ff-terminal.ts start",
    "build": "tsc -p tsconfig.json",
    "start:daemon": "node dist/daemon/daemon.js",
    "start:cli": "node dist/cli/app.js",
    "start:web": "node dist/web/server.js"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.40.1",
    "ink": "^5.0.0",
    "react": "^18.3.1",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "inquirer": "^9.2.12",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.8",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
