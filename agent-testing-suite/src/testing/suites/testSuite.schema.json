{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Test Suite Schema",
  "description": "Schema for defining agent test suites",
  "type": "object",
  "required": ["name", "description", "category", "scenarios"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique name for the test suite"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of what this suite tests"
    },
    "category": {
      "type": "string",
      "enum": ["long-horizon", "tool-usage", "reasoning", "safety"],
      "description": "Category of the test suite"
    },
    "version": {
      "type": "string",
      "default": "1.0.0",
      "description": "Semantic version of the test suite"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "prompts", "evaluation", "timeout_minutes"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name for the scenario"
          },
          "description": {
            "type": "string",
            "description": "What this scenario tests"
          },
          "prompts": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Sequence of prompts to send to the agent"
          },
          "evaluation": {
            "type": "object",
            "required": ["rubric", "assertions"],
            "properties": {
              "rubric": {
                "type": "string",
                "description": "ID of the rubric to use"
              },
              "assertions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type", "condition", "expected"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["output", "filesystem", "tool_pattern", "duration", "exit_code"]
                    },
                    "condition": {
                      "type": "string",
                      "description": "JSON path or regex condition"
                    },
                    "expected": {}
                  }
                }
              },
              "human_review": {
                "type": "boolean",
                "default": false
              }
            }
          },
          "timeout_minutes": {
            "type": "number",
            "minimum": 1,
            "description": "Maximum time for this scenario"
          },
          "expected_duration_minutes": {
            "type": "number",
            "minimum": 0,
            "description": "Expected completion time"
          }
        }
      }
    }
  }
}
