{
  "current": {
    "colors": {
      "button": "#000000",
      "background": "#ffffff",
      "text": "#333333",
      "accent": "#007ace",
      "border": "#e5e5e5",
      "sale_tag": "#ff6b6b",
      "error": "#ff4444",
      "success": "#4caf50"
    },
    "typography": {
      "font_family": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "heading_font": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "base_font_size": "16px",
      "heading_scale": 1.2,
      "line_height": 1.6
    },
    "layout": {
      "max_width": "1200px",
      "spacing_unit": "1rem",
      "border_radius": "4px",
      "button_padding": "12px 24px",
      "card_padding": "24px"
    },
    "product": {
      "image_aspect_ratio": "1.0",
      "show_vendor": true,
      "show_sku": false,
      "enable_image_zoom": true,
      "show_quantity_selector": true
    },
    "header": {
      "logo_width": "200px",
      "sticky_header": true,
      "show_search": true,
      "show_cart": true,
      "show_account": true
    },
    "footer": {
      "show_newsletter": true,
      "show_social_links": true,
      "show_payment_icons": true,
      "copyright_text": "© 2025 Your Store. All rights reserved."
    }
  }
}